<body>
    <div class="container">
        <header>
            <h1>📋 课堂智能签到</h1>
            <p class="subtitle">点击按钮完成今日考勤记录</p>
            <div class="class-name">信息技术课 - 高一 (1) 班</div>
        </header>

        <div class="stats-container">
            <div class="stat-item">
                <div class="stat-icon">✅</div>
                <div class="stat-number" id="presentCount">0</div>
                <div class="stat-label">已签到</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">⏰</div>
                <div class="stat-number" id="lateCount">0</div>
                <div class="stat-label">迟到的</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">👥</div>
                <div class="stat-number" id="totalCount">0</div>
                <div class="stat-label">总人数</div>
            </div>
        </div>

        <form id="checkinForm">
            <input type="hidden" id="teacher" value="老张">
            <input type="hidden" id="activityId" value="模板网页/通用课堂签到">
            
            <div class="input-group">
                <label for="studentName">姓名</label>
                <input type="text" id="studentName" placeholder="请输入您的姓名" required autocomplete="off">
            </div>

            <div class="input-group">
                <label for="studentClass">班级</label>
                <select id="studentClass" required>
                    <option value="">请选择班级</option>
                    <option value="高一 (1) 班">高一 (1) 班</option>
                    <option value="高一 (2) 班">高一 (2) 班</option>
                    <option value="高二 (1) 班">高二 (1) 班</option>
                </select>
            </div>

            <div class="attendance-status present" id="statusPresent">
                ✅ 签到成功！欢迎参加今天的课程
            </div>

            <button type="submit" class="submit-btn" id="submitBtn">📍 立即签到</button>
        </form>

        <div class="live-feed">
            <div class="live-feed-title">🔄 实时签到列表 (自动刷新)</div>
            <ul class="feed-list" id="feedList"></ul>
            <p class="refresh-info">每 30 秒自动更新 • 最后更新：<span id="lastUpdate">--:--</span></p>
        </div>

        <footer><p>© 2026 QuickForge 课堂教学系统 | 数据实时同步至教师端</p></footer>
    </div>

    <script>
        const teacher = '老张';
        const activityId = '通用课堂签到';
        let isSignedIn = false;

        // 格式化时间
        function formatTime(date) {
            return date.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
        }

        // 计算迟到状态
        function checkLateStatus(checkinTime) {
            const now = new Date();
            const diffMinutes = Math.floor((now - checkinTime) / 60000);
            return diffMinutes <= 5 ? '正常' : '迟到';
        }

        // 加载签到数据
        async function loadAttendanceData() {
            try {
                const response = await fetch(`/api/submissions?teacher=${teacher}&activity_id=${activityId}&limit=100`);
                const data = await response.json();

                if (data.success && Array.isArray(data.submissions)) {
                    updateStatsAndFeed(data.submissions);
                }
            } catch (error) {
                console.error('加载数据失败:', error);
            }
        }

        function updateStatsAndFeed(submissions) {
            const today = new Date().toDateString();
            const todaySubmissions = submissions.filter(s => {
                const submitDate = new Date(s._server_timestamp || Date.now()).toDateString();
                return submitDate === today;
            });

            const total = todaySubmissions.length;
            let late = 0;

            todaySubmissions.forEach(sub => {
                const timeStr = sub.data?.time;
                if (timeStr) {
                    const checkinTime = new Date(timeStr);
                    const status = checkLateStatus(checkinTime);
                    if (status === '迟到') late++;
                }
            });

            const present = total - late;

            // 更新统计
            document.getElementById('presentCount').textContent = present;
            document.getElementById('lateCount').textContent = late;
            document.getElementById('totalCount').textContent = total;

            // 更新实时列表
            const feedList = document.getElementById('feedList');
            feedList.innerHTML = todaySubmissions.slice(-20).reverse().map(sub => {
                const timeStr = sub.data?.time;
                const time = timeStr ? new Date(timeStr).toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : formatTime(new Date(sub._server_timestamp));
                
                const name = sub.data?.name || 'Anonymous';
                const status = checkLateStatus(timeStr ? new Date(timeStr) : new Date());
                
                return `
                    <li class="feed-item">
                        <span>${escapeHtml(name)}</span>
                        <div style="text-align:right;">
                            <span class="feed-time">${time}</span><br>
                            <span class="status-badge ${status === '迟到' ? 'status-late' : 'status-present'}">
                                ${status === '迟到' ? '⏰ 迟到' : '✅ 准时'}
                            </span>
                        </div>
                    </li>
                `;
            }).join('');

            document.getElementById('lastUpdate').textContent = formatTime(new Date());
        }

        async function handleCheckin(e) {
            e.preventDefault();

            if (isSignedIn) return;

            const studentName = document.getElementById('studentName').value.trim();
            const studentClass = document.getElementById('studentClass').value;

            if (!studentName || !studentClass) {
                alert('请填写完整信息！');
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.textContent = '⏳ 正在签到...';

            try {
                const now = new Date();
                const formData = new FormData();
                formData.append('teacher', teacher);
                formData.append('activity_id', activityId);
                formData.append('student_id', window.studentId || 'S001');
                formData.append('data', JSON.stringify({
                    name: studentName,
                    class: studentClass,
                    time: now.toISOString(),
                    submission_type: 'attendance_checkin',
                    client_timestamp: now.toISOString()
                }));

                const response = await fetch('/api/submit', { method: 'POST', body: formData });
                const result = await response.json();

                if (response.ok && result.success) {
                    isSignedIn = true;
                    
                    // 显示签到成功状态
                    const statusDiv = document.getElementById('statusPresent');
                    const timeStr = now.toLocaleTimeString('zh-CN', { hour: '2-digit', minute: '2-digit' });
                    const lateStatus = checkLateStatus(now);
                    
                    statusDiv.style.display = 'block';
                    statusDiv.className = `attendance-status ${lateStatus === '迟到' ? 'late' : 'present'}`;
                    statusDiv.innerHTML = `${lateStatus === '迟到' ? '⏰' : '✅'} 签到${lateStatus === '迟到' ? '(迟到)' : '成功'}！欢迎参加今天的课程<br><small>签到时间：${timeStr}</small>`;
                    
                    // 隐藏提交按钮
                    btn.style.display = 'none';
                    
                    // 重新加载数据以显示最新记录
                    setTimeout(() => loadAttendanceData(), 1000);
                    
                    alert(`✅ ${lateStatus === '迟到' ? '迟到' : '准时'}签到成功！\n签到时间：${timeStr}`);
                } else {
                    throw new Error(result.message || '未知错误');
                }
            } catch (error) {
                console.error('签到失败:', error);
                alert('❌ 签到失败：' + error.message);
                btn.disabled = false;
                btn.textContent = '📍 立即签到';
            }
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // 页面加载时初始化
        document.getElementById('checkinForm').addEventListener('submit', handleCheckin);
        loadAttendanceData();

        // 每 30 秒自动刷新
        setInterval(loadAttendanceData, 30000);
    </script>
</body>
</html>
