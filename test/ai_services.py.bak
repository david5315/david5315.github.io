# ==================== 硬编码的提示词模板 ====================
DEFAULT_PROMPT_TEMPLATE = '''你是一个专业的网页生成助手。请根据以下用户需求生成一个完整的、可直接运行的HTML页面（包含CSS和JavaScript），页面应能调用系统提供的API来实现所需功能。

目标：根据用户要求生成交互式网页。网页需接入统一数据中台，所有提交的数据通过中台接口存储，分析页面从中台查询数据并展示统计结果。

数据中台接口规范

1. 提交接口
URL：/api/submit
方法：POST
支持 Content-Type：application/json 或 multipart/form-data（用于文件上传）
必填字段（所有请求均需包含）：
  - teacher：教师用户名（例如：{{teacher}} ），必须提供。
  - activity_id：活动标识（例如 course_001），必须提供。也可使用字段名 task 作为替代，但建议统一使用 activity_id。
  - student_id：学生标识，可以是学号或匿名ID。
其他自定义字段（如题目答案、操作记录等）可任意添加。

文件上传方式（如果需要）
使用 FormData，将上述必要字段作为独立的表单字段添加，其他数据可放入一个名为 data 的 JSON 字符串中。文件字段名固定为 files，可重复添加多个文件。
示例（JavaScript）：
const formData = new FormData();
formData.append('teacher', '{{teacher}} ');
formData.append('activity_id', '{{task}}');
formData.append('student_id', 'S001');
formData.append('data', JSON.stringify({ answer1: 'A', memo: '备注' }));
for (let file of fileInput.files) {
  formData.append('files', file);
}
await fetch('/api/submit', { method: 'POST', body: formData });

纯 JSON 提交（无文件）：
await fetch('/api/submit', {
  method: 'POST',
  headers: { 'Content-Type': 'application/json' },
  body: JSON.stringify({
    teacher: '{{teacher}} ',
    activity_id: '{{task}}',
    student_id: 'S001',
    answer1: 'A',
    memo: '备注'
  })
});

2. 查询接口
URL：/api/submissions
方法：GET
参数（通过 query string 传递）：
  - teacher（必选）：教师用户名。
  - activity_id（可选）：筛选指定活动。
  - student_id（可选）：筛选指定学生。
  - limit（可选）：返回条数限制（默认100，最大500）。
  - offset（可选）：分页偏移量（默认0）。
响应示例（重要：数据实际存储在 "submissions" 字段中）：
{
  "success": true,
  "total": 200,
  "offset": 0,
  "limit": 100,
  "submissions": [              // ← 记录数组在此字段内
    {
      "teacher": "{{teacher}} ",
      "activity_id": "'{{task}}",
      "student_id": "S001",
      "answer1": "A",
      "memo": "备注",
      "_server_timestamp": "2025-03-21T14:30:00",
      "_files": [ /* 文件列表，若无则为空数组 */ ],
      "_meta": { "filename": "..." }
    }
  ]
}
解析时，应先检查 response.ok 和 data.success，然后从 data.submissions 中获取数组。

3. 文件访问
上传的文件可通过 /templates/{{teacher}}/uploads/<filename> 直接访问。在 API 返回的 _files 字段中会包含完整的 url，可直接使用。

生成要求：
- 页面应美观、响应式，使用现代化 CSS（如 Flexbox、Grid），可引入 Tailwind CSS 或自定义样式。
- 使用原生 JavaScript（ES6+）实现交互和 API 调用，无需额外框架。
- 根据用户需求合理选择调用上述 API 接口，并处理成功/失败提示。
- **获取教师和活动标识**：页面需要当前教师的用户名（teacher）和活动标识（activity_id/task）。建议通过解析当前页面的 URL 路径动态获取（因为页面可能以静态方式部署，如直接访问 `/templates/教师名/.../活动名/页面.html`）。示例代码：
  ```javascript
  const pathParts = window.location.pathname.split('/');
  // 教师名通常在路径的第二段（索引2），需解码URL编码的中文
  const teacher = decodeURIComponent(pathParts[2]);
  // 活动名通常为最后一级文件夹名（倒数第二段）
  const activityId = decodeURIComponent(pathParts[pathParts.length - 2]);


 '''




# ==================== 辅助函数：安全文件名 ====================
def safe_filename(filename, default='unnamed'):
    """
    生成安全的文件名，保留中文、字母、数字、下划线、连字符和点，
    并防止路径遍历。
    """
    # 提取文件名部分，去除路径
    filename = os.path.basename(filename)
    # 替换不允许的字符为下划线
    # 允许：字母、数字、中文字符、下划线、连字符、点
    filename = re.sub(r'[^\w\u4e00-\u9fa5.-]', '_', filename)
    # 去除前导点（防止隐藏文件）
    filename = filename.lstrip('.')
    if not filename:
        filename = default
    return filename


# ==================== 配置管理函数 ====================

def load_ai_config():
    """初始化或获取内存中的配置"""
    global _ai_config
    if _ai_config is not None:
        return _ai_config

    # 直接使用硬编码的默认配置
    config = DEFAULT_AI_CONFIG.copy()
    # 注意：深拷贝，避免后续修改影响默认值
    import copy
    _ai_config = copy.deepcopy(config)
    print("✅ 使用硬编码的 AI 配置")
    return _ai_config

def get_ai_config():
    """获取当前配置"""
    return load_ai_config()

def save_ai_config(config):
    """保存配置到内存（不再写入文件）"""
    global _ai_config
    _ai_config = config
    return True

def set_logged_user_key(user_key):
    """将当前登录用户的 user_key 保存到内存配置中"""
    config = get_ai_config()
    config['logged_user_key'] = user_key
    save_ai_config(config)

def get_master_key():
    config = get_ai_config()
    return config.get('master_key', '')

def check_ai_quota():
    """
    检查AI使用配额，返回 (can_use, message, api_key, using_master)
    现在 always using_master=False，强制使用 temp_key 并检查剩余次数。
    """
    config = get_ai_config()
    user_info = get_current_user_info()
    if not user_info:
        return False, '请先登录', None, False

    # 检查账号有效期
    expiry = user_info.get('expiry_date')
    if expiry:
        try:
            expiry_date = datetime.strptime(expiry, '%Y-%m-%d').date()
            if datetime.now().date() > expiry_date:
                return False, '账号已过期', None, False
        except:
            pass

    # 检查剩余次数
    remaining = user_info.get('remaining_uses', 0)
    if remaining <= 0:
        return False, '剩余使用次数不足', None, False

    # 使用内存中的 temp_key
    temp_key = config.get('temp_key')
    if not temp_key:
        return False, '系统未配置临时密钥', None, False

    # 检查 temp_key 有效期
    temp_key_expiry = config.get('temp_key_expiry')
    if temp_key_expiry:
        try:
            exp = datetime.strptime(temp_key_expiry, '%Y-%m-%d %H:%M:%S')
            if datetime.now() > exp:
                return False, '临时密钥已过期', None, False
        except:
            pass

    return True, '', temp_key, False

# 创建忽略证书验证的适配器
class TLSAdapter(requests.adapters.HTTPAdapter):
    def init_poolmanager(self, connections, maxsize, block=False):
        ctx = ssl.create_default_context()
        ctx.set_ciphers('DEFAULT@SECLEVEL=1')
        ctx.check_hostname = False
        ctx.verify_mode = ssl.CERT_NONE
        self.poolmanager = poolmanager.PoolManager(
            num_pools=connections,
            maxsize=maxsize,
            block=block,
            ssl_version=ssl.PROTOCOL_TLS,
            ssl_context=ctx)

def create_ai_analyzer():
    """创建AI分析器实例"""
    try:
        session = requests.Session()
        session.mount('https://', TLSAdapter())
        return session
    except Exception as e:
        print(f"❌ 创建AI分析器失败: {e}")
        return None

def extract_html_from_response(ai_response):
    """从AI响应中提取HTML代码"""
    import re
    patterns = [
        r'(<!DOCTYPE html>.*?</html>)',
        r'(<html>.*?</html>)',
    ]
    for pattern in patterns:
        match = re.search(pattern, ai_response, re.DOTALL | re.IGNORECASE)
        if match:
            return match.group(1)
    return ai_response

def safe_join_teacher_path(teacher_username, subpath):
    """安全拼接教师目录下的路径，防止路径遍历"""
    base = os.path.realpath(os.path.join('templates', teacher_username))
    target = os.path.realpath(os.path.join(base, subpath))
    if not target.startswith(base):
        return None
    return target

